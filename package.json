{
  "name": "tiny-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Tiny Tools — a fast, free, privacy-friendly collection of browser-based utilities.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "highlight.js": "^11.10.0",
    "marked": "^14.1.3",
    "next": "^14.2.35",
    "qrcode": "1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sanitize-html": "^2.13.1"
  },
  "devDependencies": {
    "@lhci/cli": "0.14.0",
    "@playwright/test": "1.61.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "20.16.13",
    "@types/qrcode": "1.5.5",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "@types/sanitize-html": "^2.13.0",
    "@vitejs/plugin-react": "4.3.2",
    "@vitest/coverage-v8": "2.1.3",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vitest": "2.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
