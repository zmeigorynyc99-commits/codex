# Public site URL used for canonical links, sitemap and Open Graph tags.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://tinytools.example

# Privacy-friendly, cookie-free analytics placeholder.
# Leave empty to disable analytics entirely (the default).
# Example (Plausible-compatible self-hosted endpoint):
#   NEXT_PUBLIC_ANALYTICS_DOMAIN=tinytools.example
#   NEXT_PUBLIC_ANALYTICS_SRC=https://analytics.example/script.js
NEXT_PUBLIC_ANALYTICS_DOMAIN=
NEXT_PUBLIC_ANALYTICS_SRC=

# Donation link (e.g. a Ko-fi / Liberapay / GitHub Sponsors URL).
# Leave empty to hide the footer donation button.
NEXT_PUBLIC_DONATE_URL=https://ko-fi.com/zmeigorynyc

# Set to "true" to render advertisement placeholders.
NEXT_PUBLIC_ENABLE_ADS=false

# ---------------------------------------------------------------------------
# Linux Tutorials CMS (server-side runtime variables — NOT inlined at build)
# ---------------------------------------------------------------------------

# Where the embedded SQLite database file lives. In Docker this is on the
# persistent `cms-data` volume. Locally it defaults to ./data/cms.db.
CMS_DB_PATH=./data/cms.db

# Directory for uploaded tutorial images (served via /api/uploads/<file>).
CMS_UPLOAD_DIR=./data/uploads

# Salt for hashing visitor IPs stored with forum/comment/contact submissions
# (used for moderation only; never displayed). Set to a long random string.
CMS_IP_SALT=change-me-to-a-long-random-string

# ---- Search engine / SEO ----
# Site-ownership verification tokens. Paste only the token value from each tool.
# Google Search Console (HTML-tag method): https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools:
NEXT_PUBLIC_BING_SITE_VERIFICATION=
# Yandex Webmaster (optional):
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=

# IndexNow key (runtime) — instantly notifies Bing/Yandex when you publish a
# tutorial. Any random 8–128 hex string; the key is served at /indexnow.
INDEXNOW_KEY=

# Support links shown after posts, on /support and in the footer. Each button
# uses its own variable; leave empty to point that button at the on-site
# /support page. A single Ko-fi page works for all three.
#   "Buy me a coffee" -> NEXT_PUBLIC_COFFEE_URL
#   "Support with $1" -> NEXT_PUBLIC_SUPPORT_URL
#   Footer donate      -> NEXT_PUBLIC_DONATE_URL (above)
NEXT_PUBLIC_COFFEE_URL=https://ko-fi.com/zmeigorynyc
NEXT_PUBLIC_SUPPORT_URL=https://ko-fi.com/zmeigorynyc

# Used only by scripts/create-admin.mjs if you prefer env vars over CLI args.
# Create an admin with:  node scripts/create-admin.mjs <email> <password>
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
